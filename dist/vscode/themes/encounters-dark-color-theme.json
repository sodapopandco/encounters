{
  "$schema": "vscode://schemas/color-theme",
  "name": "Encounters Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#181818",
    "editor.foreground": "#e0e0e0",
    "editor.selectionBackground": "#303030",
    "editor.lineHighlightBackground": "#202020",
    "editor.findMatchHighlightBackground": "#ffd44040",
    "editorCursor.foreground": "#ffd440",
    "editorWhitespace.foreground": "#303030",
    "editorIndentGuide.background1": "#303030",
    "editorLineNumber.foreground": "#303030",
    "editorLineNumber.activeForeground": "#606060",
    "editorGutter.background": "#181818",
    "editorBracketMatch.background": "#303030",
    "editorBracketMatch.border": "#606060",

    "activityBar.background": "#202020",
    "activityBar.foreground": "#e0e0e0",
    "activityBarBadge.background": "#ffd440",
    "activityBarBadge.foreground": "#181818",

    "sideBar.background": "#202020",
    "sideBar.foreground": "#b0b0b0",
    "sideBarTitle.foreground": "#e0e0e0",
    "sideBarSectionHeader.background": "#303030",

    "statusBar.background": "#202020",
    "statusBar.foreground": "#b0b0b0",

    "tab.activeBackground": "#181818",
    "tab.activeForeground": "#e0e0e0",
    "tab.inactiveBackground": "#202020",
    "tab.inactiveForeground": "#606060",
    "tab.border": "#181818",
    "editorGroupHeader.tabsBackground": "#202020",

    "titleBar.activeBackground": "#202020",
    "titleBar.activeForeground": "#b0b0b0",
    "titleBar.inactiveBackground": "#202020",

    "input.background": "#181818",
    "input.foreground": "#e0e0e0",
    "input.border": "#303030",
    "focusBorder": "#ffd440",

    "button.background": "#ffd440",
    "button.foreground": "#181818",
    "button.hoverBackground": "#ffe280",

    "list.activeSelectionBackground": "#303030",
    "list.activeSelectionForeground": "#e0e0e0",
    "list.hoverBackground": "#202020",
    "list.focusBackground": "#303030",

    "panel.background": "#202020",
    "panel.border": "#303030",
    "panelTitle.activeForeground": "#e0e0e0",
    "panelTitle.inactiveForeground": "#606060",

    "terminal.background": "#181818",
    "terminal.foreground": "#b0b0b0",
    "terminal.ansiBlack": "#181818",
    "terminal.ansiRed": "#ac0000",
    "terminal.ansiGreen": "#008b00",
    "terminal.ansiYellow": "#bf9400",
    "terminal.ansiBlue": "#0051ac",
    "terminal.ansiMagenta": "#740091",
    "terminal.ansiCyan": "#007773",
    "terminal.ansiWhite": "#b0b0b0",
    "terminal.ansiBrightBlack": "#606060",
    "terminal.ansiBrightRed": "#e14b4b",
    "terminal.ansiBrightGreen": "#49c249",
    "terminal.ansiBrightYellow": "#f3cd4c",
    "terminal.ansiBrightBlue": "#4b92e1",
    "terminal.ansiBrightMagenta": "#ae49c8",
    "terminal.ansiBrightCyan": "#48afac",
    "terminal.ansiBrightWhite": "#e0e0e0",

    "gitDecoration.addedResourceForeground": "#008b00",
    "gitDecoration.modifiedResourceForeground": "#740091",
    "gitDecoration.deletedResourceForeground": "#ac0000",
    "gitDecoration.untrackedResourceForeground": "#49c249",
    "gitDecoration.conflictingResourceForeground": "#e14b4b",

    "editorError.foreground": "#e14b4b",
    "editorWarning.foreground": "#ae49c8",
    "editorInfo.foreground": "#f3cd4c"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#606060"
      }
    },
    {
      "scope": [
        "variable",
        "support.function"
      ],
      "settings": {
        "foreground": "#e14b4b"
      }
    },
    {
      "scope": [
        "storage",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f1924c"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.tag",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#f3cd4c"
      }
    },
    {
      "scope": [
        "string",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#49c249"
      }
    },
    {
      "scope": [
        "support.constant",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#48afac"
      }
    },
    {
      "scope": [
        "constant",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#4b92e1"
      }
    },
    {
      "scope": [
        "keyword",
        "meta.at-rule"
      ],
      "settings": {
        "foreground": "#ae49c8"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#f58ac7"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#b0b0b0"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#f0f0f0"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ffffff",
        "background": "#ac0000"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ac0000"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#008b00"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#740091"
      }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": {
        "foreground": "#c63989"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#4b92e1"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#49c249"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#f1924c"
      }
    }
  ]
}
